<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OpenPatro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenPatro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenPatro">

    <Grid x:Name="RootGrid"
            Loaded="RootGrid_Loaded"
          PointerPressed="RootGrid_PointerPressed"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="20">
        <Grid.Resources>
            <Style x:Key="RailButtonStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="48" />
                <Setter Property="Height" Value="48" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ButtonRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                        <VisualState x:Name="Checked">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="CheckedPointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="CheckedPressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="CheckedDisabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Indeterminate" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="20"
                Padding="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center">
                <Grid x:Name="TitleBarDragRegion"
                      Height="48"
                      Margin="0,0,0,16">
                    <Image x:Name="SidebarLogo"
                           Source="Assets/Square44x44Logo.scale-200.png"
                           ImageFailed="SidebarLogo_ImageFailed"
                           Width="32"
                           Height="32"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                </Grid>

                <ToggleButton x:Name="CalendarButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE787;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="StockMarketButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="Stock Market">
                    <FontIcon Glyph="&#xE9D2;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="RashifalButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="राशिफल (Rashifal)">
                    <FontIcon Glyph="&#xE734;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="ShubhaSaitButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="शुभ साइत (Shubha Sait)">
                    <FontIcon Glyph="&#xE8BF;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="DateConverterButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="मिति रूपान्तरण (Date Converter)">
                    <FontIcon Glyph="&#xE895;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="SettingsButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="20,0,0,0">
            <Grid x:Name="CalendarSection"
                  Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ═══ Month header ═══ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Calendar.MonthTitleNepali, Mode=OneWay}"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="20" />
                        <TextBlock Text="{x:Bind ViewModel.Calendar.MonthTitleEnglish, Mode=OneWay}"
                                   Opacity="0.52"
                                   FontSize="13"
                                   Margin="1,2,0,0"
                                   CharacterSpacing="40" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <Button Command="{x:Bind ViewModel.Calendar.PreviousMonthCommand, Mode=OneWay}"
                                Width="36" Height="36" Padding="0"
                                CornerRadius="18"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                ToolTipService.ToolTip="Previous month">
                            <SymbolIcon Symbol="Back" />
                        </Button>
                        <ComboBox x:Name="CalendarYearPicker"
                                  MinWidth="110"
                                  HorizontalAlignment="Center"
                                  ItemsSource="{x:Bind ViewModel.Calendar.AvailableYears, Mode=OneWay}"
                                  SelectionChanged="CalendarYearPicker_SelectionChanged" />
                        <ComboBox x:Name="CalendarMonthPicker"
                                  MinWidth="130"
                                  HorizontalAlignment="Center"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{x:Bind ViewModel.Calendar.AvailableMonths, Mode=OneWay}"
                                  SelectionChanged="CalendarMonthPicker_SelectionChanged" />
                        <Button Command="{x:Bind ViewModel.Calendar.NextMonthCommand, Mode=OneWay}"
                                Width="36" Height="36" Padding="0"
                                CornerRadius="18"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                ToolTipService.ToolTip="Next month">
                            <SymbolIcon Symbol="Forward" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ═══ Calendar body ═══ -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="CalendarLayoutHost" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- ─── Weekday header strip ─── -->
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="10"
                                Padding="0,10"
                                Margin="0,0,0,10"
                                Width="{Binding ElementName=CalendarDaysView, Path=ActualWidth}"
                                HorizontalAlignment="Center">
                            <Grid x:Name="WeekdayHeaderGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="आइत" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.62"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="सोम" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.62"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="मङ्गल" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.62"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="बुध" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.62"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="बिहि" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.62"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="5" Text="शुक्र" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.62"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="6" Text="शनि" FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="12" FontWeight="Medium" Opacity="0.42"
                                           HorizontalAlignment="Center"
                                           Foreground="#EF6C6C" />
                            </Grid>
                        </Border>

                        <!-- ─── Calendar grid ─── -->
                        <GridView x:Name="CalendarDaysView"
                                  x:FieldModifier="private"
                                  Grid.Row="1"
                                  HorizontalAlignment="Center"
                                  ItemsSource="{x:Bind ViewModel.Calendar.Days, Mode=OneWay}"
                                  IsItemClickEnabled="True"
                                  ItemClick="CalendarDaysView_ItemClick"
                                  SelectionMode="None"
                                  BorderThickness="0"
                                  Padding="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="{Binding BorderThickness}"
                                            CornerRadius="12"
                                            Margin="3"
                                            Padding="10,8,10,8"
                                            Opacity="{Binding CellOpacity}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Day number -->
                                            <TextBlock Text="{Binding Record.BsDayText}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding DayForegroundBrush}" />

                                            <!-- Event -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding EventText}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"
                                                       Foreground="{Binding SecondaryForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       MaxLines="1"
                                                       ToolTipService.ToolTip="{Binding EventText}" />

                                            <!-- Tithi -->
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Record.Tithi}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="10"
                                                       Margin="0,2,0,0"
                                                       Foreground="{Binding TertiaryForegroundBrush}"
                                                       VerticalAlignment="Bottom"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       ToolTipService.ToolTip="{Binding Record.Tithi}" />

                                            <!-- AD day number -->
                                            <TextBlock Grid.Row="3"
                                                       Text="{Binding AdDayText}"
                                                       FontSize="10"
                                                       Foreground="{Binding TertiaryForegroundBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       Opacity="0.8" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <!-- ═══ Detail overlay panel ═══ -->
                        <Border x:Name="DetailPanel"
                                Grid.Row="1"
                                Width="400"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Visibility="Collapsed"
                                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="0">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DetailTransform" X="32" />
                            </Border.RenderTransform>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="0">

                                    <!-- Detail header -->
                                    <Grid Padding="24,20,24,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedBsFullDate, Mode=OneWay}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedAdDateText, Mode=OneWay}"
                                                       Opacity="0.56"
                                                       FontSize="13" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Click="CloseDetailPanel_Click"
                                                Width="32" Height="32" Padding="0"
                                                CornerRadius="16"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                VerticalAlignment="Top">
                                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                                        </Button>
                                    </Grid>

                                    <!-- Holiday badge -->
                                    <Border Visibility="{x:Bind ViewModel.Calendar.SelectedHolidayVisibility, Mode=OneWay}"
                                            Background="#1AEF6C6C"
                                            CornerRadius="6"
                                            Padding="10,5"
                                            Margin="24,0,24,12"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="🔴 बिदा (Holiday)"
                                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#EF6C6C" />
                                    </Border>

                                    <!-- Divider -->
                                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="24,0" />

                                    <!-- Info rows -->
                                    <StackPanel Spacing="14" Padding="24,16,24,16">
                                        <!-- Lunar / Tithi -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="तिथि"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="11"
                                                       Opacity="0.44"
                                                       FontWeight="Medium" />
                                            <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedLunarText, Mode=OneWay}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Panchanga -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="पञ्चाङ्ग"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="11"
                                                       Opacity="0.44"
                                                       FontWeight="Medium" />
                                            <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedPanchanga, Mode=OneWay}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="14"
                                                       Opacity="0.82"
                                                       TextWrapping="Wrap"
                                                       LineHeight="22" />
                                        </StackPanel>

                                        <!-- Events -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="घटना / पर्व"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="11"
                                                       Opacity="0.44"
                                                       FontWeight="Medium" />
                                            <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedEventText, Mode=OneWay}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap"
                                                       LineHeight="24" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Divider -->
                                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="24,0" />

                                    <!-- Notes section -->
                                    <StackPanel Spacing="10" Padding="24,16,24,20">
                                        <TextBlock Text="📝 Personal Note"
                                                   FontSize="12"
                                                   Opacity="0.52"
                                                   FontWeight="Medium" />
                                        <TextBox Text="{x:Bind ViewModel.Calendar.SelectedNote, Mode=TwoWay}"
                                                 AcceptsReturn="True"
                                                 MinHeight="100"
                                                 CornerRadius="10"
                                                 TextWrapping="Wrap"
                                                 PlaceholderText="Add a note for this day…" />
                                        <Button Command="{x:Bind ViewModel.Calendar.SaveNoteCommand, Mode=OneWay}"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                CornerRadius="8"
                                                HorizontalAlignment="Left"
                                                Padding="16,6">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                                <TextBlock Text="Save" FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsSection"
                  Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <TextBlock Text="Settings" FontSize="30" FontWeight="SemiBold" />
                        <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="16">
                                <ToggleSwitch Header="Start with Windows"
                                              IsOn="{x:Bind ViewModel.Settings.StartWithWindows, Mode=TwoWay}" />
                                <TextBlock Text="{x:Bind ViewModel.Settings.LastSyncLabel, Mode=OneWay}" Opacity="0.72" />
                                <Button Command="{x:Bind ViewModel.Settings.RefreshCommand, Mode=OneWay}" HorizontalAlignment="Left">Refresh current data now</Button>
                            </StackPanel>
                        </Border>
                        <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Storage" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Calendar database" Opacity="0.56" />
                                <TextBlock Text="{x:Bind ViewModel.Settings.CalendarDatabasePath, Mode=OneWay}" TextWrapping="Wrap" />
                                <TextBlock Text="User database" Opacity="0.56" Margin="0,8,0,0" />
                                <TextBlock Text="{x:Bind ViewModel.Settings.UserDatabasePath, Mode=OneWay}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Connect &amp; Support" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="This app is free and open source. You can connect with the developer or explore the project."
                                           Opacity="0.72"
                                           TextWrapping="Wrap" />

                                <Border Padding="12" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid ColumnSpacing="12" MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="24" Height="24" VerticalAlignment="Center">
                                            <SymbolIcon Symbol="Globe" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="GitHub" FontWeight="SemiBold" />
                                            <TextBlock Text="https://github.com/menaceXnadin" Opacity="0.62" TextWrapping="Wrap" />
                                            <TextBlock Text="Explore and star the project" Opacity="0.62" FontSize="12" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Click="GitHubSupportButton_Click" VerticalAlignment="Center">Open link</Button>
                                    </Grid>
                                </Border>

                                <Border Padding="12" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid ColumnSpacing="12" MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="24" Height="24" VerticalAlignment="Center">
                                            <SymbolIcon Symbol="Contact" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="LinkedIn" FontWeight="SemiBold" />
                                            <TextBlock Text="https://www.linkedin.com/in/nadintamang/" Opacity="0.62" TextWrapping="Wrap" />
                                            <TextBlock Text="Professional connection" Opacity="0.62" FontSize="12" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Click="LinkedInSupportButton_Click" VerticalAlignment="Center">Open link</Button>
                                    </Grid>
                                </Border>

                                <Border Padding="12" CornerRadius="12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid ColumnSpacing="12" MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="24" Height="24" VerticalAlignment="Center">
                                            <SymbolIcon Symbol="Shop" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="eSewa (Support / Easter Egg)" FontWeight="SemiBold" />
                                            <TextBlock Text="Support the project through eSewa" Opacity="0.62" FontSize="12" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Click="EsewaSupportButton_Click" VerticalAlignment="Center">Open</Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="StockMarketSection"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ROW 1: Header Bar -->
                <Grid Margin="0,0,0,20" Padding="24,16" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="NEPSE Stock Market" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Border Padding="12,6" CornerRadius="16" Background="{x:Bind ViewModel.StockMarket.MarketStatusBadgeColor, Mode=OneWay}">
                            <TextBlock Text="{x:Bind ViewModel.StockMarket.MarketStatus, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" />
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.StockMarket.LastUpdated, Mode=OneWay}" Opacity="0.7" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="2" Command="{x:Bind ViewModel.StockMarket.RefreshCommand, Mode=OneWay}" Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.StockMarket.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.StockMarket.IsBusy), Mode=OneWay}"
                                      Width="40" Height="40" HorizontalAlignment="Center" Margin="0,40,0,40" />

                        <TextBlock Text="{x:Bind ViewModel.StockMarket.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.StockMarket.ErrorMessage), Mode=OneWay}"
                                   Foreground="#EF4444" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,20,0,20" />

                        <!-- ROW 2: Main Indices - 4 Cards in Grid -->
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- NEPSE -->
                            <Border Grid.Column="0" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="NEPSE" Opacity="0.6" FontSize="13" />
                                    <TextBlock Text="{x:Bind ViewModel.StockMarket.NepseValue, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="▼" FontSize="12" Foreground="#EF4444" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.NepseChange, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Float, Sensitive, Sensitive Float from MajorIndices collection -->
                            <Border Grid.Column="1" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" DataContext="{x:Bind ViewModel.StockMarket.MajorIndices[0], Mode=OneWay}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding Name}" Opacity="0.6" FontSize="13" />
                                    <TextBlock Text="{Binding Value}" FontSize="32" FontWeight="Bold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="▼" FontSize="12" Foreground="#EF4444" />
                                        <TextBlock Text="{Binding Change}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                        <TextBlock Text="{Binding ChangePercent}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" DataContext="{x:Bind ViewModel.StockMarket.MajorIndices[1], Mode=OneWay}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding Name}" Opacity="0.6" FontSize="13" />
                                    <TextBlock Text="{Binding Value}" FontSize="32" FontWeight="Bold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="▼" FontSize="12" Foreground="#EF4444" />
                                        <TextBlock Text="{Binding Change}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                        <TextBlock Text="{Binding ChangePercent}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="3" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" DataContext="{x:Bind ViewModel.StockMarket.MajorIndices[2], Mode=OneWay}">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding Name}" Opacity="0.6" FontSize="13" />
                                    <TextBlock Text="{Binding Value}" FontSize="32" FontWeight="Bold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="▼" FontSize="12" Foreground="#EF4444" />
                                        <TextBlock Text="{Binding Change}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                        <TextBlock Text="{Binding ChangePercent}" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- MARKET ACTIVITY Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="MARKET ACTIVITY" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Border Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Turnover" Opacity="0.6" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.TotalTurnover, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="1" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Traded shares" Opacity="0.6" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.TotalTradedShares, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="2" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Transactions" Opacity="0.6" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.TotalTransactions, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- MARKET SIZE Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="MARKET SIZE" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Border Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Scrips traded" Opacity="0.6" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.ScriptsTraded, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="1" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Market cap" Opacity="0.6" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.MarketCap, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="2" Padding="24,20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Float market cap" Opacity="0.6" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.FloatMarketCap, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- MARKET BREADTH Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="MARKET BREADTH" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Border Padding="24,28" CornerRadius="12" Background="#1522C55E">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.AdvancedCount, Mode=OneWay}" FontSize="48" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center" />
                                        <TextBlock Text="Advanced" Opacity="0.85" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="1" Padding="24,28" CornerRadius="12" Background="#15EF4444">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.DeclinedCount, Mode=OneWay}" FontSize="48" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" />
                                        <TextBlock Text="Declined" Opacity="0.85" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="2" Padding="24,28" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.UnchangedCount, Mode=OneWay}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Unchanged" Opacity="0.7" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="3" Padding="24,28" CornerRadius="12" Background="#1522C55E">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.PositiveCircuitCount, Mode=OneWay}" FontSize="48" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center" />
                                        <TextBlock Text="Positive circuit" Opacity="0.85" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="4" Padding="24,28" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.StockMarket.NegativeCircuitCount, Mode=OneWay}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Negative circuit" Opacity="0.7" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- ROW 5 & 6: Sector Indices and Top Stocks Side by Side -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- LEFT: Sector Indices Table -->
                            <Border Padding="0" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="0">
                                    <!-- Section Header -->
                                    <Grid Padding="24,20" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12,12,0,0">
                                        <TextBlock Text="SECTOR INDICES" FontSize="16" FontWeight="Bold" />
                                    </Grid>
                                    
                                    <!-- Table Header -->
                                    <Grid Padding="24,16" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SECTOR" FontSize="12" FontWeight="SemiBold" Opacity="0.6" />
                                        <TextBlock Grid.Column="1" Text="INDEX" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="%" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" />
                                    </Grid>
                                    
                                    <!-- Table Rows -->
                                    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.StockMarket.SectorIndices, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="24,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                        <TextBlock Grid.Column="2" Text="{Binding ChangePercent}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                            
                            <!-- RIGHT: Top Stocks with Tabs -->
                            <Border Grid.Column="1" Padding="0" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="0">
                                    <!-- Tab Headers -->
                                    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Click="TopGainersTab_Click" Padding="12,16" CornerRadius="12,0,0,0" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE735;" FontSize="12" />
                                                <TextBlock Text="GAINERS" FontSize="11" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Click="TopLosersTab_Click" Padding="12,16" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74B;" FontSize="12" />
                                                <TextBlock Text="LOSERS" FontSize="11" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" Click="TopTurnoverTab_Click" Padding="12,16" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE9D2;" FontSize="12" />
                                                <TextBlock Text="TURNOVER" FontSize="11" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="3" Click="TopVolumeTab_Click" Padding="12,16" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE9F9;" FontSize="12" />
                                                <TextBlock Text="VOLUME" FontSize="11" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="4" Click="TopTransactionsTab_Click" Padding="12,16" CornerRadius="0,12,0,0" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8FD;" FontSize="12" />
                                                <TextBlock Text="TRADES" FontSize="11" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    
                                    <!-- Table Header -->
                                    <Grid Padding="24,16" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SYMBOL" FontSize="12" FontWeight="SemiBold" Opacity="0.6" />
                                        <TextBlock Grid.Column="1" Text="LTP" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="CHG" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="3" Text="%" FontSize="12" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" />
                                    </Grid>
                                    
                                    <!-- Table Rows - Dynamic based on selected tab -->
                                    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.StockMarket.CurrentTopStocksList, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="24,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                            <Border Width="32" Height="32" CornerRadius="16" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                                                <Image Source="{Binding LogoUrl}" Stretch="UniformToFill" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Symbol}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding LastTradedPrice}" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Change}" FontSize="15" FontWeight="SemiBold" Foreground="#22C55E" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Metric}" FontSize="15" FontWeight="SemiBold" Foreground="#22C55E" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ROW 7: Live Market Data Table -->
                        <Border Padding="0" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="0">
                                <!-- Section Header -->
                                <Grid Padding="24,20" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12,12,0,0">
                                    <TextBlock Text="LIVE MARKET DATA" FontSize="16" FontWeight="Bold" />
                                </Grid>
                                
                                <!-- Table Header -->
                                <Grid Padding="24,14" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="40" />
                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                        <ColumnDefinition Width="Auto" MinWidth="100" />
                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                        <ColumnDefinition Width="Auto" MinWidth="110" />
                                        <ColumnDefinition Width="Auto" MinWidth="110" />
                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="" FontSize="11" FontWeight="SemiBold" Opacity="0.6" />
                                    <TextBlock Grid.Column="1" Text="SYMBOL" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2" Text="NAME" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="3" Text="SECTOR" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="4" Text="OPEN" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="5" Text="HIGH" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="6" Text="LOW" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="7" Text="LTP" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="8" Text="PREV" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="9" Text="CHG %" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="10" Text="VOLUME" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="11" Text="TURNOVER" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="12" Text="TRADES" FontSize="11" FontWeight="SemiBold" Opacity="0.6" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                </Grid>
                                
                                <!-- Table Rows -->
                                <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.StockMarket.LiveCompanies, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="24,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" MinWidth="40" />
                                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                                        <ColumnDefinition Width="*" MinWidth="150" />
                                                        <ColumnDefinition Width="Auto" MinWidth="100" />
                                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                                        <ColumnDefinition Width="Auto" MinWidth="110" />
                                                        <ColumnDefinition Width="Auto" MinWidth="110" />
                                                        <ColumnDefinition Width="Auto" MinWidth="80" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="32" Height="32" CornerRadius="16" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                                        <Image Source="{Binding LogoUrl}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Symbol}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding SecurityName}" FontSize="13" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Sector}" Opacity="0.7" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="4" Text="{Binding OpenPrice}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="5" Text="{Binding HighPrice}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="6" Text="{Binding LowPrice}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="7" Text="{Binding LastTradedPrice}" FontWeight="Bold" FontSize="13" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="8" Text="{Binding PreviousClose}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="9" Text="{Binding ChangePercent}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="10" Text="{Binding Quantity}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="11" Text="{Binding Turnover}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                    <TextBlock Grid.Column="12" Text="{Binding Transactions}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

