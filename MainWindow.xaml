                        <TextBlock Text="राशिफल"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Rashifal — Horoscope"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{x:Bind ViewModel.Rashifal.RefreshCommand, Mode=OneWay}"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.Rashifal.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.Rashifal.IsBusy), Mode=OneWay}"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.Rashifal.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.Rashifal.ErrorMessage), Mode=OneWay}"
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap" />
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="RashifalTypePicker"
                                          Header="प्रकार (Type)"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="RashifalTypePicker_SelectionChanged">
                                    <ComboBoxItem Content="दैनिक (Daily)" Tag="D" />
                                    <ComboBoxItem Content="साप्ताहिक (Weekly)" Tag="W" />
                                    <ComboBoxItem Content="मासिक (Monthly)" Tag="M" />
                                    <ComboBoxItem Content="वार्षिक (Yearly)" Tag="Y" />
                                </ComboBox>
                                <ComboBox x:Name="RashifalZodiacPicker"
                                          Grid.Column="1"
                                          Header="राशि (Zodiac Sign)"
                                          SelectedIndex="0"
                                          Margin="16,0,0,0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="RashifalZodiacPicker_SelectionChanged">
                                    <ComboBoxItem Content="मेष (Aries)" Tag="aries" />
                                    <ComboBoxItem Content="वृष (Taurus)" Tag="taurus" />
                                    <ComboBoxItem Content="मिथुन (Gemini)" Tag="gemini" />
                                    <ComboBoxItem Content="कर्कट (Cancer)" Tag="cancer" />
                                    <ComboBoxItem Content="सिंह (Leo)" Tag="leo" />
                                    <ComboBoxItem Content="कन्या (Virgo)" Tag="virgo" />
                                    <ComboBoxItem Content="तुला (Libra)" Tag="libra" />
                                    <ComboBoxItem Content="वृश्चिक (Scorpio)" Tag="scorpio" />
                                    <ComboBoxItem Content="धनु (Sagittarius)" Tag="sagittarius" />
                                    <ComboBoxItem Content="मकर (Capricorn)" Tag="capricorn" />
                                    <ComboBoxItem Content="कुम्भ (Aquarius)" Tag="aquarius" />
                                    <ComboBoxItem Content="मीन (Pisces)" Tag="pisces" />
                                </ComboBox>
                            </Grid>
                        </Border>
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{x:Bind ViewModel.Rashifal.Title, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Valid for:" Opacity="0.56" FontSize="13" />
                                    <TextBlock Text="{x:Bind ViewModel.Rashifal.ValidForDate, Mode=OneWay}"
                                               Opacity="0.56" FontSize="13" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Padding="24" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                MinHeight="200">
                            <StackPanel Spacing="12">
                                <TextBlock Text="भविष्यवाणी"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.Rashifal.PredictionText, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           LineHeight="28" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ShubhaSaitSection"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="शुभ साइत"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Shubha Sait — Auspicious Dates"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Click="SaitRefreshButton_Click"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.ShubhaSait.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.ShubhaSait.IsBusy), Mode=OneWay}"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.ShubhaSait.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.ShubhaSait.ErrorMessage), Mode=OneWay}"
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap" />
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="SaitYearPicker"
                                          Header="वर्ष (Year)"
                                          ItemsSource="{x:Bind ViewModel.ShubhaSait.AvailableYears, Mode=OneWay}"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="SaitYearPicker_SelectionChanged" />
                                <ComboBox x:Name="SaitCategoryPicker"
                                          Grid.Column="1"
                                          Header="वर्ग (Category)"
                                          ItemsSource="{x:Bind ViewModel.ShubhaSait.AvailableCategories, Mode=OneWay}"
                                          DisplayMemberPath="NepaliName"
                                          Margin="16,0,0,0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="SaitCategoryPicker_SelectionChanged" />
                            </Grid>
                        </Border>
                        <Border Padding="24" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                MinHeight="120">
                            <StackPanel Spacing="16">
                                <TextBlock Text="शुभ दिनहरू (Auspicious Days by Month)"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{x:Bind ViewModel.ShubhaSait.MonthWiseAuspiciousDays, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="8" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                                <GridView ItemsSource="{Binding Days}"
                                                          SelectionMode="None"
                                                          IsItemClickEnabled="False"
                                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <GridView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="56" Height="56" CornerRadius="28"
                                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                    Margin="4">
                                                                <TextBlock Text="{Binding}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="20"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </GridView.ItemTemplate>
                                                </GridView>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="DateConverterSection"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="मिति रूपान्तरण"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Date Converter — BS ↔ AD"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.DateConverter.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.DateConverter.IsBusy), Mode=OneWay}"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.DateConverter.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.DateConverter.ErrorMessage), Mode=OneWay}"
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap" />
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="16">
                                <ComboBox x:Name="DateConverterDirectionPicker"
                                          Header="Direction"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="DateConverterDirection_SelectionChanged">
                                    <ComboBoxItem Content="BS → AD (बि.सं. → ई.सं.)" Tag="BS" />
                                    <ComboBoxItem Content="AD → BS (ई.सं. → बि.सं.)" Tag="AD" />
                                </ComboBox>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DateConverterYearBox"
                                             Header="Year"
                                             PlaceholderText="2082"
                                             InputScope="Number"
                                             MaxLength="4"
                                             BeforeTextChanging="DateConverterNumericOnly_BeforeTextChanging"
                                             TextChanged="DateConverterInputPart_TextChanged"
                                             KeyDown="DateConverterInputPart_KeyDown" />
                                    <ComboBox x:Name="DateConverterMonthPicker"
                                              Grid.Column="1"
                                              Header="महिना (Month)"
                                              PlaceholderText="Choose month"
                                              SelectionChanged="DateConverterMonthPicker_SelectionChanged"
                                              KeyDown="DateConverterInputPart_KeyDown">
                                        <ComboBoxItem Content="बैशाख" Tag="1" />
                                        <ComboBoxItem Content="जेठ" Tag="2" />
                                        <ComboBoxItem Content="असार" Tag="3" />
                                        <ComboBoxItem Content="साउन" Tag="4" />
                                        <ComboBoxItem Content="भदौ" Tag="5" />
                                        <ComboBoxItem Content="असोज" Tag="6" />
                                        <ComboBoxItem Content="कात्तिक" Tag="7" />
                                        <ComboBoxItem Content="मंसिर" Tag="8" />
                                        <ComboBoxItem Content="पुष" Tag="9" />
                                        <ComboBoxItem Content="माघ" Tag="10" />
                                        <ComboBoxItem Content="फाल्गुन" Tag="11" />
                                        <ComboBoxItem Content="चैत" Tag="12" />
                                    </ComboBox>
                                    <TextBox x:Name="DateConverterDayBox"
                                             Grid.Column="2"
                                             Header="Day"
                                             PlaceholderText="28"
                                             InputScope="Number"
                                             MaxLength="2"
                                             BeforeTextChanging="DateConverterNumericOnly_BeforeTextChanging"
                                             TextChanged="DateConverterInputPart_TextChanged"
                                             KeyDown="DateConverterInputPart_KeyDown" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="DateConverterConvertButton"
                                            Command="{x:Bind ViewModel.DateConverter.ConvertCommand, Mode=OneWay}"
                                            Style="{ThemeResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE895;" FontSize="14" />
                                            <TextBlock Text="Convert" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="DateConverterClearButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                                            <TextBlock Text="Clear" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{x:Bind ViewModel.DateConverter.RefreshCommand, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                            <TextBlock Text="Re-convert" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Padding="24" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                Visibility="{x:Bind BoolToVisibility(ViewModel.DateConverter.HasResult), Mode=OneWay}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="रूपान्तरण परिणाम (Conversion Result)"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <Grid RowSpacing="12" ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="AD Date (ई.सं.)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultAdDate, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Row="1" Text="BS Date (बि.सं.)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultBsDate, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Row="2" Text="Tithi (तिथि)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultTithiLabel, Mode=OneWay}" />
                                    <TextBlock Grid.Row="3" Text="Nepal Sambat (ने.सं.)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultNsYear, Mode=OneWay}" />
                                    <TextBlock Grid.Row="4" Text="Chandrama (चन्द्रमा)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultChandrama, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
