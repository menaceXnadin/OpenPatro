<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OpenPatro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenPatro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenPatro">

    <Grid x:Name="RootGrid"
            Loaded="RootGrid_Loaded"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="20">
        <Grid.Resources>
            <Style x:Key="RailButtonStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="48" />
                <Setter Property="Height" Value="48" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ButtonRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Checked">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="20"
                Padding="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center">
                <Grid x:Name="TitleBarDragRegion"
                      Height="48"
                      Margin="0,0,0,16">
                    <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                           Width="32"
                           Height="32"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                </Grid>

                <ToggleButton x:Name="CalendarButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE787;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="RashifalButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="राशिफल (Rashifal)">
                    <FontIcon Glyph="&#xE734;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="ShubhaSaitButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="शुभ साइत (Shubha Sait)">
                    <FontIcon Glyph="&#xE8BF;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="DateConverterButton"
                              Style="{StaticResource RailButtonStyle}"
                              ToolTipService.ToolTip="मिति रूपान्तरण (Date Converter)">
                    <FontIcon Glyph="&#xE895;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="SettingsButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="20,0,0,0">
            <Grid x:Name="CalendarSection"
                  Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.Calendar.MonthTitleNepali, Mode=OneWay}"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.Calendar.MonthTitleEnglish, Mode=OneWay}"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                        <Button Command="{x:Bind ViewModel.Calendar.PreviousMonthCommand, Mode=OneWay}" MinWidth="40"><FontIcon Glyph="&#xE76B;" /></Button>
                        <Button Command="{x:Bind ViewModel.Calendar.NextMonthCommand, Mode=OneWay}" MinWidth="40"><FontIcon Glyph="&#xE76C;" /></Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="CalendarLayoutHost" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                            <Grid x:Name="WeekdayHeaderGrid" Margin="0,0,0,16"
                              Width="{Binding ElementName=CalendarDaysView, Path=ActualWidth}"
                              HorizontalAlignment="Left">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="TextAlignment" Value="Center" />
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="आइतवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="1" Text="सोमवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="2" Text="मङ्गलवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="3" Text="बुधवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="4" Text="बिहिवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="5" Text="शुक्रवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="6" Text="शनिवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.38" />
                        </Grid>

                        <GridView x:Name="CalendarDaysView"
                                  x:FieldModifier="private"
                                  Grid.Row="1"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{x:Bind ViewModel.Calendar.Days, Mode=OneWay}"
                                  IsItemClickEnabled="True"
                                  ItemClick="CalendarDaysView_ItemClick"
                                  SelectionMode="None"
                                  BorderThickness="0"
                                  Padding="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="{Binding BorderThickness}"
                                            CornerRadius="8"
                                            Margin="6"
                                            Padding="12"
                                            Opacity="{Binding CellOpacity}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Record.BsDayText}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding DayForegroundBrush}" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding EventText}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="12"
                                                       Margin="0,6,0,0"
                                                       Foreground="{Binding SecondaryForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="WrapWholeWords"
                                                       MaxLines="1"
                                                       ToolTipService.ToolTip="{Binding EventText}" />
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Record.Tithi}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"
                                                       Foreground="{Binding TertiaryForegroundBrush}"
                                                       VerticalAlignment="Bottom"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       ToolTipService.ToolTip="{Binding Record.Tithi}" />
                                            <TextBlock Grid.Row="3"
                                                       Text="{Binding AdDayText}"
                                                       FontSize="11"
                                                       Foreground="{Binding TertiaryForegroundBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <Border x:Name="DetailPanel"
                                Grid.Row="1"
                                Width="384"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Visibility="Collapsed"
                                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="24">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DetailTransform" X="32" />
                            </Border.RenderTransform>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedBsFullDate, Mode=OneWay}"
                                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedAdDateText, Mode=OneWay}"
                                                   Opacity="0.72" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Click="CloseDetailPanel_Click"><FontIcon Glyph="&#xE711;" /></Button>
                                </Grid>

                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedHolidayLabel, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.Calendar.SelectedHolidayVisibility, Mode=OneWay}"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedLunarText, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18" />
                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedPanchanga, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           Opacity="0.76"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedEventText, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           TextWrapping="Wrap" />

                                <TextBox Header="Personal note"
                                         Text="{x:Bind ViewModel.Calendar.SelectedNote, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         MinHeight="120"
                                         TextWrapping="Wrap" />
                                <Button Command="{x:Bind ViewModel.Calendar.SaveNoteCommand, Mode=OneWay}"
                                        HorizontalAlignment="Left">
                                    Save note
                                </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsSection"
                  Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Settings" FontSize="30" FontWeight="SemiBold" />
                    <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                        <StackPanel Spacing="16">
                            <ToggleSwitch Header="Start with Windows"
                                          IsOn="{x:Bind ViewModel.Settings.StartWithWindows, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.Settings.LastSyncLabel, Mode=OneWay}" Opacity="0.72" />
                            <Button Command="{x:Bind ViewModel.Settings.RefreshCommand, Mode=OneWay}" HorizontalAlignment="Left">Refresh current data now</Button>
                        </StackPanel>
                    </Border>
                    <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Storage" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Calendar database" Opacity="0.56" />
                            <TextBlock Text="{x:Bind ViewModel.Settings.CalendarDatabasePath, Mode=OneWay}" TextWrapping="Wrap" />
                            <TextBlock Text="User database" Opacity="0.56" Margin="0,8,0,0" />
                            <TextBlock Text="{x:Bind ViewModel.Settings.UserDatabasePath, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid x:Name="RashifalSection"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="राशिफल"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Rashifal — Horoscope"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{x:Bind ViewModel.Rashifal.RefreshCommand, Mode=OneWay}"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.Rashifal.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.Rashifal.IsBusy), Mode=OneWay}"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.Rashifal.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.Rashifal.ErrorMessage), Mode=OneWay}"
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap" />
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="RashifalTypePicker"
                                          Header="प्रकार (Type)"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="RashifalTypePicker_SelectionChanged">
                                    <ComboBoxItem Content="दैनिक (Daily)" Tag="D" />
                                    <ComboBoxItem Content="साप्ताहिक (Weekly)" Tag="W" />
                                    <ComboBoxItem Content="मासिक (Monthly)" Tag="M" />
                                    <ComboBoxItem Content="वार्षिक (Yearly)" Tag="Y" />
                                </ComboBox>
                                <ComboBox x:Name="RashifalZodiacPicker"
                                          Grid.Column="1"
                                          Header="राशि (Zodiac Sign)"
                                          SelectedIndex="0"
                                          Margin="16,0,0,0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="RashifalZodiacPicker_SelectionChanged">
                                    <ComboBoxItem Content="मेष (Aries)" Tag="aries" />
                                    <ComboBoxItem Content="वृष (Taurus)" Tag="taurus" />
                                    <ComboBoxItem Content="मिथुन (Gemini)" Tag="gemini" />
                                    <ComboBoxItem Content="कर्कट (Cancer)" Tag="cancer" />
                                    <ComboBoxItem Content="सिंह (Leo)" Tag="leo" />
                                    <ComboBoxItem Content="कन्या (Virgo)" Tag="virgo" />
                                    <ComboBoxItem Content="तुला (Libra)" Tag="libra" />
                                    <ComboBoxItem Content="वृश्चिक (Scorpio)" Tag="scorpio" />
                                    <ComboBoxItem Content="धनु (Sagittarius)" Tag="sagittarius" />
                                    <ComboBoxItem Content="मकर (Capricorn)" Tag="capricorn" />
                                    <ComboBoxItem Content="कुम्भ (Aquarius)" Tag="aquarius" />
                                    <ComboBoxItem Content="मीन (Pisces)" Tag="pisces" />
                                </ComboBox>
                            </Grid>
                        </Border>
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{x:Bind ViewModel.Rashifal.Title, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Valid for:" Opacity="0.56" FontSize="13" />
                                    <TextBlock Text="{x:Bind ViewModel.Rashifal.ValidForDate, Mode=OneWay}"
                                               Opacity="0.56" FontSize="13" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Padding="24" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                MinHeight="200">
                            <StackPanel Spacing="12">
                                <TextBlock Text="भविष्यवाणी"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.Rashifal.PredictionText, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           LineHeight="28" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ShubhaSaitSection"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="शुभ साइत"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Shubha Sait — Auspicious Dates"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Click="SaitRefreshButton_Click"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.ShubhaSait.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.ShubhaSait.IsBusy), Mode=OneWay}"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.ShubhaSait.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.ShubhaSait.ErrorMessage), Mode=OneWay}"
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap" />
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="SaitYearPicker"
                                          Header="वर्ष (Year)"
                                          ItemsSource="{x:Bind ViewModel.ShubhaSait.AvailableYears, Mode=OneWay}"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="SaitYearPicker_SelectionChanged" />
                                <ComboBox x:Name="SaitCategoryPicker"
                                          Grid.Column="1"
                                          Header="वर्ग (Category)"
                                          ItemsSource="{x:Bind ViewModel.ShubhaSait.AvailableCategories, Mode=OneWay}"
                                          DisplayMemberPath="NepaliName"
                                          Margin="16,0,0,0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="SaitCategoryPicker_SelectionChanged" />
                                <ComboBox x:Name="SaitMonthPicker"
                                          Grid.Column="2"
                                          Header="महिना (Month)"
                                          ItemsSource="{x:Bind ViewModel.ShubhaSait.AvailableMonths, Mode=OneWay}"
                                          DisplayMemberPath="DisplayName"
                                          Margin="16,0,0,0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="SaitMonthPicker_SelectionChanged" />
                            </Grid>
                        </Border>
                        <Border Padding="24" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                MinHeight="120">
                            <StackPanel Spacing="16">
                                <TextBlock Text="शुभ दिनहरू (Auspicious Days)"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <GridView ItemsSource="{x:Bind ViewModel.ShubhaSait.AuspiciousDays, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="56" Height="56" CornerRadius="28"
                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Margin="4">
                                                <TextBlock Text="{Binding}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="20"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="DateConverterSection"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="मिति रूपान्तरण"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Date Converter — BS ↔ AD"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="0,0,16,0">
                        <ProgressRing IsActive="{x:Bind ViewModel.DateConverter.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind BoolToVisibility(ViewModel.DateConverter.IsBusy), Mode=OneWay}"
                                      Width="32" Height="32"
                                      HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.DateConverter.ErrorMessage, Mode=OneWay}"
                                   Visibility="{x:Bind StringToVisibility(ViewModel.DateConverter.ErrorMessage), Mode=OneWay}"
                                   Foreground="#FF6B6B"
                                   TextWrapping="Wrap" />
                        <Border Padding="20" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                            <StackPanel Spacing="16">
                                <ComboBox x:Name="DateConverterDirectionPicker"
                                          Header="Direction"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="DateConverterDirection_SelectionChanged">
                                    <ComboBoxItem Content="BS → AD (बि.सं. → ई.सं.)" Tag="BS" />
                                    <ComboBoxItem Content="AD → BS (ई.सं. → बि.सं.)" Tag="AD" />
                                </ComboBox>
                                <TextBox Header="Date (YYYY-MM-DD)"
                                         PlaceholderText="e.g. 2082-12-28"
                                         Text="{x:Bind ViewModel.DateConverter.InputDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{x:Bind ViewModel.DateConverter.ConvertCommand, Mode=OneWay}"
                                            Style="{ThemeResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE895;" FontSize="14" />
                                            <TextBlock Text="Convert" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{x:Bind ViewModel.DateConverter.RefreshCommand, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                            <TextBlock Text="Re-convert" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Padding="24" CornerRadius="16"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                Visibility="{x:Bind BoolToVisibility(ViewModel.DateConverter.HasResult), Mode=OneWay}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="रूपान्तरण परिणाम (Conversion Result)"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <Grid RowSpacing="12" ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="AD Date (ई.सं.)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultAdDate, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Row="1" Text="BS Date (बि.सं.)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultBsDate, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Row="2" Text="Tithi (तिथि)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultTithiLabel, Mode=OneWay}" />
                                    <TextBlock Grid.Row="3" Text="Nepal Sambat (ने.सं.)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultNsYear, Mode=OneWay}" />
                                    <TextBlock Grid.Row="4" Text="Chandrama (चन्द्रमा)" Opacity="0.56" FontFamily="{StaticResource AppNepaliFontFamily}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{x:Bind ViewModel.DateConverter.ResultChandrama, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
