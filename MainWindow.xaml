<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OpenPatro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenPatro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenPatro">

    <Grid x:Name="RootGrid"
            Loaded="RootGrid_Loaded"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="20">
        <Grid.Resources>
            <Style x:Key="RailButtonStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="48" />
                <Setter Property="Height" Value="48" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ButtonRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Checked">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRoot" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="20"
                Padding="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center">
                <Grid x:Name="TitleBarDragRegion"
                      Height="48"
                      Margin="0,0,0,16">
                    <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                           Width="32"
                           Height="32"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                </Grid>

                <ToggleButton x:Name="CalendarButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE787;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="SearchButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
                <ToggleButton x:Name="SettingsButton"
                              Style="{StaticResource RailButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="20,0,0,0">
            <Grid x:Name="CalendarSection"
                  Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.Calendar.MonthTitleNepali, Mode=OneWay}"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="34"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.Calendar.MonthTitleEnglish, Mode=OneWay}"
                                   Opacity="0.68"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                        <Button Command="{x:Bind ViewModel.Calendar.PreviousMonthCommand, Mode=OneWay}" MinWidth="40"><FontIcon Glyph="&#xE76B;" /></Button>
                        <Button Command="{x:Bind ViewModel.Calendar.NextMonthCommand, Mode=OneWay}" MinWidth="40"><FontIcon Glyph="&#xE76C;" /></Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="CalendarLayoutHost" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="WeekdayHeaderGrid" Margin="0,0,0,16"
                              Width="{Binding ElementName=CalendarDaysView, Path=ActualWidth}"
                              HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="आइतवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="1" Text="सोमवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="2" Text="मङ्गलवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="3" Text="बुधवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="4" Text="बिहिवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="5" Text="शुक्रवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.56" />
                            <TextBlock Grid.Column="6" Text="शनिवार" FontFamily="{StaticResource AppNepaliFontFamily}" Opacity="0.38" />
                        </Grid>

                        <GridView x:Name="CalendarDaysView"
                                  x:FieldModifier="private"
                                  Grid.Row="1"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{x:Bind ViewModel.Calendar.Days, Mode=OneWay}"
                                  IsItemClickEnabled="True"
                                  ItemClick="CalendarDaysView_ItemClick"
                                  SelectionMode="None"
                                  BorderThickness="0"
                                  Padding="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="{Binding BorderThickness}"
                                            CornerRadius="8"
                                            Margin="6"
                                            Padding="12"
                                            Opacity="{Binding CellOpacity}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Record.BsDayText}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding DayForegroundBrush}" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding EventText}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="12"
                                                       Margin="0,6,0,0"
                                                       Foreground="{Binding SecondaryForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="WrapWholeWords"
                                                       MaxLines="1"
                                                       ToolTipService.ToolTip="{Binding EventText}" />
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Record.Tithi}"
                                                       FontFamily="{StaticResource AppNepaliFontFamily}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"
                                                       Foreground="{Binding TertiaryForegroundBrush}"
                                                       VerticalAlignment="Bottom"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       ToolTipService.ToolTip="{Binding Record.Tithi}" />
                                            <TextBlock Grid.Row="3"
                                                       Text="{Binding AdDayText}"
                                                       FontSize="11"
                                                       Foreground="{Binding TertiaryForegroundBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <Border x:Name="DetailPanel"
                                Grid.Row="1"
                                Width="384"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Visibility="Collapsed"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="24">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="DetailTransform" X="32" />
                            </Border.RenderTransform>
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedBsFullDate, Mode=OneWay}"
                                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedAdDateText, Mode=OneWay}"
                                                   Opacity="0.72" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Click="CloseDetailPanel_Click"><FontIcon Glyph="&#xE711;" /></Button>
                                </Grid>

                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedHolidayLabel, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.Calendar.SelectedHolidayVisibility, Mode=OneWay}"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedLunarText, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18" />
                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedPanchanga, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           Opacity="0.76"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.Calendar.SelectedEventText, Mode=OneWay}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           TextWrapping="Wrap" />

                                <TextBox Header="Personal note"
                                         Text="{x:Bind ViewModel.Calendar.SelectedNote, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         MinHeight="120"
                                         TextWrapping="Wrap" />
                                <Button Command="{x:Bind ViewModel.Calendar.SaveNoteCommand, Mode=OneWay}"
                                        HorizontalAlignment="Left">
                                    Save note
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="SearchSection"
                  Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Search" FontSize="30" FontWeight="SemiBold" />
                    <TextBlock Text="Search calendar events and your notes." Opacity="0.72" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchQueryBox"
                                 Text="{x:Bind ViewModel.Search.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Event, tithi, date, note"
                                 KeyDown="SearchQueryBox_KeyDown" />
                        <Button Grid.Column="1" Command="{x:Bind ViewModel.Search.SearchCommand, Mode=OneWay}">Search</Button>
                    </Grid>
                    <ListView ItemsSource="{x:Bind ViewModel.Search.Results, Mode=OneWay}"
                              IsItemClickEnabled="True"
                              ItemClick="SearchResultsView_ItemClick"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16"
                                        Margin="0,0,0,8"
                                        CornerRadius="12"
                                        Background="{ThemeResource LayerFillColorAltBrush}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="18" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Subtitle}" Opacity="0.72" />
                                        <TextBlock Text="{Binding NotePreview}" Opacity="0.72" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>

            <Grid x:Name="SettingsSection"
                  Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock Text="Settings" FontSize="30" FontWeight="SemiBold" />
                    <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                        <StackPanel Spacing="16">
                            <ToggleSwitch Header="Start with Windows"
                                          IsOn="{x:Bind ViewModel.Settings.StartWithWindows, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.Settings.LastSyncLabel, Mode=OneWay}" Opacity="0.72" />
                            <Button Command="{x:Bind ViewModel.Settings.RefreshCommand, Mode=OneWay}" HorizontalAlignment="Left">Refresh current data now</Button>
                        </StackPanel>
                    </Border>
                    <Border Padding="20" CornerRadius="16" Background="{ThemeResource LayerFillColorAltBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Storage" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Calendar database" Opacity="0.56" />
                            <TextBlock Text="{x:Bind ViewModel.Settings.CalendarDatabasePath, Mode=OneWay}" TextWrapping="Wrap" />
                            <TextBlock Text="User database" Opacity="0.56" Margin="0,8,0,0" />
                            <TextBlock Text="{x:Bind ViewModel.Settings.UserDatabasePath, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
