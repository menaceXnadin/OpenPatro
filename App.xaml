<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OpenPatro.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenPatro"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="AppLatinFontFamily">Segoe UI Variable Text</FontFamily>
            <FontFamily x:Key="AppNepaliFontFamily">ms-appx:///Assets/Fonts/NotoSansDevanagari.ttf#Noto Sans Devanagari</FontFamily>

            <SolidColorBrush x:Key="ShellStrokeBrush" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#B3FFFFFF" />
            <SolidColorBrush x:Key="CalendarGridBrush" Color="#14FFFFFF" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
