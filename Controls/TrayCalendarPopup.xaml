<UserControl
    x:Class="OpenPatro.Controls.TrayCalendarPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Width="340"
            Padding="16"
            CornerRadius="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <StackPanel Spacing="12">

            <!-- Month header and navigation -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding MonthTitleNepali}"
                               FontFamily="{StaticResource AppNepaliFontFamily}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding MonthTitleEnglish}"
                               Opacity="0.68"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="4">
                    <Button Command="{Binding PreviousMonthCommand}" Width="32" Height="32" Padding="0">
                        <FontIcon Glyph="&#xE76B;" FontSize="12" />
                    </Button>
                    <Button Command="{Binding NextMonthCommand}" Width="32" Height="32" Padding="0">
                        <FontIcon Glyph="&#xE76C;" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Day-of-week header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="आ" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.56" />
                <TextBlock Grid.Column="1" Text="सो" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.56" />
                <TextBlock Grid.Column="2" Text="मं" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.56" />
                <TextBlock Grid.Column="3" Text="बु" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.56" />
                <TextBlock Grid.Column="4" Text="बि" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.56" />
                <TextBlock Grid.Column="5" Text="शु" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.56" />
                <TextBlock Grid.Column="6" Text="श" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="11" Opacity="0.38" />
            </Grid>

            <!-- Calendar day grid -->
            <GridView ItemsSource="{Binding Days}"
                      IsItemClickEnabled="True"
                      ItemClick="DaysGrid_ItemClick"
                      SelectionMode="None"
                      BorderThickness="0"
                      Padding="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Disabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Width" Value="43" />
                        <Setter Property="Height" Value="40" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding BackgroundBrush}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="{Binding BorderThickness}"
                                CornerRadius="6"
                                Opacity="{Binding CellOpacity}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="1">
                                <TextBlock Text="{Binding Record.BsDayText}"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding DayForegroundBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Text="{Binding AdDayText}"
                                           FontSize="9"
                                           Foreground="{Binding TertiaryForegroundBrush}"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Selected day detail -->
            <Border x:Name="SelectedDayDetail"
                    Visibility="Collapsed"
                    Padding="12"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding SelectedDay.Record.BsFullDate}"
                               FontFamily="{StaticResource AppNepaliFontFamily}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedDay.Record.AdDateText}"
                               Opacity="0.72"
                               FontSize="12" />
                    <TextBlock Text="{Binding SelectedEventText}"
                               FontFamily="{StaticResource AppNepaliFontFamily}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Visibility="{Binding SelectedHolidayVisibility}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>