<UserControl
    x:Class="OpenPatro.Controls.TrayCalendarPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TrayPopupSurfaceBrush" Color="#111214" />
        <SolidColorBrush x:Key="TrayPopupPanelBrush" Color="#181A1E" />
        <SolidColorBrush x:Key="TrayPopupBorderBrush" Color="#2A2D33" />
        <SolidColorBrush x:Key="TrayPopupTextBrush" Color="#F4F4F4" />
        <SolidColorBrush x:Key="TrayPopupMutedBrush" Color="#AAADB3" />
        <SolidColorBrush x:Key="TrayPopupSubtleBrush" Color="#20242A" />
        <SolidColorBrush x:Key="TrayPopupHolidayBrush" Color="#FF6060" />

        <Style x:Key="TrayPopupIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TrayPopupTextBrush}" />
            <Setter Property="Background" Value="#242830" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

        <Border Padding="20,18,20,20"
            CornerRadius="0"
            Background="{StaticResource TrayPopupSurfaceBrush}"
            BorderBrush="{StaticResource TrayPopupBorderBrush}"
            BorderThickness="1">
        <StackPanel Spacing="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding TodayBsFullDate}"
                               FontFamily="{StaticResource AppNepaliFontFamily}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TrayPopupTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding TodayAdDateText}"
                               FontSize="14"
                               Foreground="{StaticResource TrayPopupMutedBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource TrayPopupIconButtonStyle}"
                        Command="{Binding OpenMainWindowCommand}"
                        ToolTipService.ToolTip="Open full app">
                    <FontIcon Glyph="&#xE8A7;" FontSize="16" />
                </Button>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding MonthTitleNepali}"
                               FontFamily="{StaticResource AppNepaliFontFamily}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TrayPopupTextBrush}" />
                    <TextBlock Text="{Binding MonthTitleEnglish}"
                               FontSize="14"
                               Foreground="{StaticResource TrayPopupMutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Command="{Binding PreviousMonthCommand}" Style="{StaticResource TrayPopupIconButtonStyle}">
                        <FontIcon Glyph="&#xE76B;" FontSize="13" />
                    </Button>
                    <Button Command="{Binding NextMonthCommand}" Style="{StaticResource TrayPopupIconButtonStyle}">
                        <FontIcon Glyph="&#xE76C;" FontSize="13" />
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="#1FFFFFFF" />

            <Grid Width="336"
                  HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="आ" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupMutedBrush}" />
                <TextBlock Grid.Column="1" Text="सो" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupMutedBrush}" />
                <TextBlock Grid.Column="2" Text="मं" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupMutedBrush}" />
                <TextBlock Grid.Column="3" Text="बु" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupMutedBrush}" />
                <TextBlock Grid.Column="4" Text="बि" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupMutedBrush}" />
                <TextBlock Grid.Column="5" Text="शु" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupMutedBrush}" />
                <TextBlock Grid.Column="6" Text="श" TextAlignment="Center" FontFamily="{StaticResource AppNepaliFontFamily}" FontSize="12" Foreground="{StaticResource TrayPopupHolidayBrush}" />
            </Grid>

            <GridView x:Name="CalendarDaysGrid"
                      Width="336"
                      HorizontalAlignment="Center"
                      ItemsSource="{Binding Days}"
                      IsItemClickEnabled="True"
                      ItemClick="DaysGrid_ItemClick"
                      SelectionMode="None"
                      BorderThickness="0"
                      Padding="0"
                      IsTabStop="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Disabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Width" Value="48" />
                        <Setter Property="Height" Value="56" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding BackgroundBrush}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="{Binding BorderThickness}"
                                CornerRadius="{Binding CornerRadius}"
                                Margin="1"
                                Opacity="{Binding CellOpacity}">
                            <Grid MinWidth="46" MinHeight="54">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Record.BsDayText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,4,0,0"
                                           FontFamily="{StaticResource AppNepaliFontFamily}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding DayForegroundBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AdDayText}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,7"
                                           FontSize="11"
                                           Foreground="{Binding TertiaryForegroundBrush}"
                                           TextAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Border x:Name="SelectedDayDetail"
                    Visibility="{Binding SelectedDayVisibility}"
                    Padding="16"
                    CornerRadius="18"
                    Background="{StaticResource TrayPopupPanelBrush}"
                    BorderBrush="{StaticResource TrayPopupBorderBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              VerticalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding SelectedHolidayLabel}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TrayPopupHolidayBrush}"
                                   Visibility="{Binding SelectedHolidayVisibility}" />
                        <TextBlock Text="{Binding SelectedEventText}"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="15"
                                   Foreground="{StaticResource TrayPopupTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedPanchanga}"
                                   FontFamily="{StaticResource AppNepaliFontFamily}"
                                   FontSize="12"
                                   Foreground="{StaticResource TrayPopupMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </StackPanel>
    </Border>
</UserControl>